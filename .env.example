# Telegram Bot (Required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Notion Integration (Required)
NOTION_TOKEN=your_notion_integration_token_here

# Notion Database (Optional - will auto-create if not provided)
# If provided, must be shared with the integration
NOTION_DATABASE_ID=

# Notion Parent Page (Required for auto-create mode)
# The database will be created as a child of this page
# The page must be shared with the integration
NOTION_PARENT_PAGE_ID=your_parent_page_id_here

# Optional: OpenAI for enhanced extraction
OPENAI_API_KEY=

# Optional: Render URL for webhook
RENDER_EXTERNAL_URL=https://your-app.onrender.com
